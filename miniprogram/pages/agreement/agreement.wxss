.container {
  padding: 20rpx;
  height: 100vh;
  background-color: #f5f5f5;
}

.header {
  padding: 30rpx 0;
  border-bottom: 2rpx solid #e0e0e0;
  margin-bottom: 30rpx;
}

.header .title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

.content {
  padding: 0 10rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-top: 30rpx;
  margin-bottom: 15rpx;
}

.section-content {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}
