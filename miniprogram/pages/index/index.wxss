.container {
  padding: 20rpx;
  height: 100vh;
  background-color: #f5f5f5;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: white;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.user-info {
  display: flex;
  align-items: center;
}

.user-info image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-info text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.logout-btn {
  padding: 15rpx 30rpx;
  background-color: #ff4d4f;
  color: white;
  border: none;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.camera-list {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #e0e0e0;
}

.cameras {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.camera-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  transition: all 0.3s ease;
}

.camera-item:hover {
  border-color: #667eea;
  box-shadow: 0 2rpx 10rpx rgba(102, 126, 234, 0.2);
}

.camera-item image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.camera-info {
  flex: 1;
}

.camera-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.camera-brand {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.camera-price {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #ff4d4f;
}
