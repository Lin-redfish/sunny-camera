.container {
  padding: 20rpx;
  height: 100vh;
  background-color: #f5f5f5;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #e0e0e0;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-info image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-info text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.logout-btn {
  padding: 10rpx 30rpx;
  background: #ff4d4f;
  color: white;
  border: none;
  border-radius: 5rpx;
  font-size: 24rpx;
}

/* 功能入口模块 */
.function-entrances {
  display: flex;
  justify-content: space-around;
  background-color: white;
  border-radius: 10rpx;
  padding: 30rpx 0;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.entrance-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 20%;
}

.entrance-item image {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 15rpx;
}

.entrance-item text {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

.camera-list {
  background-color: white;
  border-radius: 10rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #e0e0e0;
}

.cameras {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.camera-item {
  width: calc(50% - 10rpx);
  background-color: #f9f9f9;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 5rpx rgba(0, 0, 0, 0.1);
}

.camera-item image {
  width: 100%;
  height: 200rpx;
  border-radius: 5rpx;
  margin-bottom: 15rpx;
}

.camera-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.camera-name {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
}

.camera-brand {
  font-size: 20rpx;
  color: #666;
}

.camera-price {
  font-size: 22rpx;
  font-weight: bold;
  color: #ff4d4f;
  margin-top: 5rpx;
}
