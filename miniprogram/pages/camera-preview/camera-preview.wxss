.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 20rpx;
}

.header {
  background-color: #667eea;
  color: white;
  padding: 40rpx 30rpx 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
}

.camera-list {
  padding: 20rpx;
}

.camera-item {
  display: flex;
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.camera-item image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.camera-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.camera-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.camera-brand {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.camera-price {
  font-size: 28rpx;
  color: #ff6b6b;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.camera-status {
  font-size: 22rpx;
  color: #4ecdc4;
  background-color: rgba(78, 205, 196, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  align-self: flex-start;
}

.camera-status.rented {
  color: #999;
  background-color: rgba(153, 153, 153, 0.1);
}