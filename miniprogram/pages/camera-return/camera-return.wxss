.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 20rpx;
}

.header {
  background-color: #667eea;
  color: white;
  padding: 40rpx 30rpx 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
}

.rental-list {
  padding: 20rpx;
}

.rental-item {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.rental-info {
  flex: 1;
  margin-right: 20rpx;
}

.camera-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.rental-date {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.rental-price {
  font-size: 26rpx;
  color: #ff6b6b;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.rental-status {
  font-size: 22rpx;
  color: #ff6b6b;
  background-color: rgba(255, 107, 107, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  align-self: flex-start;
  display: inline-block;
}

.rental-status.normal {
  color: #4ecdc4;
  background-color: rgba(78, 205, 196, 0.1);
}

.return-btn {
  background-color: #667eea;
  color: white;
  border: none;
  border-radius: 8rpx;
  padding: 15rpx 30rpx;
  font-size: 24rpx;
  font-weight: bold;
  margin-top: 20rpx;
}

.return-btn.disabled {
  background-color: #999;
  color: white;
}

.empty {
  background-color: white;
  border-radius: 10rpx;
  padding: 60rpx 20rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
  margin-top: 40rpx;
}