.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header {
  background-color: #667eea;
  color: white;
  padding: 40rpx 30rpx 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
}

.review-form {
  background-color: white;
  margin: 20rpx;
  border-radius: 10rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.form-group {
  margin-bottom: 30rpx;
}

.label {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.star-rating {
  display: flex;
  gap: 20rpx;
}

.star {
  font-size: 40rpx;
  color: #ddd;
  cursor: pointer;
  padding: 5rpx 10rpx;
}

.star.active {
  color: #ffd700;
}

textarea {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 15rpx;
  font-size: 24rpx;
  color: #333;
  resize: none;
}

.submit-btn {
  background-color: #667eea;
  color: white;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin-top: 20rpx;
}