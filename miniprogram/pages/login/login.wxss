.container {
  padding: 40rpx;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.logo {
  margin-top: 100rpx;
  margin-bottom: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: white;
  padding: 20rpx;
}

.logo .title {
  margin-top: 30rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: white;
}

.logo .subtitle {
  margin-top: 15rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-area {
  width: 100%;
  max-width: 600rpx;
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.wechat-login-btn {
  width: 100%;
  padding: 25rpx;
  background: #07C160;
  color: white;
  border: none;
  border-radius: 10rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(7, 193, 96, 0.4);
}

.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 15rpx;
}

.test-login-btn {
  width: 100%;
  padding: 25rpx;
  background: #FF9500;
  color: white;
  border: none;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(255, 149, 0, 0.4);
}

.test-icon {
  width: 35rpx;
  height: 35rpx;
  margin-right: 15rpx;
}

.tip {
  margin-top: 60rpx;
  font-size: 24rpx;
  color: white;
  text-align: center;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.agreement-link {
  color: #fff;
  text-decoration: underline;
}
