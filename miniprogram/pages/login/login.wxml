<view class="container">
  <view class="logo">
    <image src="../../images/camera.png" mode="aspectFit"></image>
    <text class="title">相机预约系统</text>
    <text class="subtitle">一键登录，开启摄影之旅</text>
  </view>
  
  <view class="login-area">
    <button class="wechat-login-btn" bindtap="wxLogin">
      <image class="wechat-icon" src="../../images/wechat.png" mode="aspectFit"></image>
      <text>微信一键登录</text>
    </button>
    
    <button class="test-login-btn" bindtap="testLogin">
      <image class="test-icon" src="../../images/test.png" mode="aspectFit"></image>
      <text>测试模式</text>
    </button>
  </view>
  
  <view class="tip">
    <text>登录即表示同意</text>
    <navigator url="../agreement/agreement" class="agreement-link">用户协议</navigator>
    <text>和</text>
    <navigator url="../privacy/privacy" class="agreement-link">隐私政策</navigator>
  </view>
</view>